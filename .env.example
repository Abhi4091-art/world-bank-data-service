# Data360 API configuration
# Copy this file to .env and adjust as needed.

DATA360_API_BASE_URL=https://data360api.worldbank.org
DATA360_API_TIMEOUT=30
DATA360_API_MAX_RETRIES=3

# Query parameters (semicolon-separated)
DATA360_DATABASE_ID=WB_WDI
DATA360_INDICATORS=SP.POP.TOTL;NY.GDP.PCAP.CD;SL.UEM.TOTL.ZS
DATA360_COUNTRIES=GBR;USA;DEU;FRA;JPN
DATA360_TIME_PERIODS=2018;2019;2020;2021;2022;2023

# Output
DATA360_OUTPUT_DIR=output

# Set to "true" to use local sample data instead of hitting the API
DATA360_USE_SAMPLE_DATA=false
DATA360_SAMPLE_DATA_PATH=data/samples/sample_response.json